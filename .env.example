# Required
DATABASE_URL=ecto://USER:PASS@HOST/DATABASE
SECRET_KEY_BASE=change-me-generate-with-openssl-rand-base64-64

# Self-hosted mode (enables dashboard, disables marketing pages)
SELFHOSTED=true

# Local registration is open by default. After creating the accounts you trust at
# /users/register, set this to false to close the registration page.
# LOCAL_REGISTRATION_ENABLED=false

# Host configuration
PHX_HOST=localhost
PORT=4000

# URL generation (for links in the app)
# PHX_SCHEME=https
# PHX_URL_PORT=443

# Set to "true" to force HTTPS redirects
# Only needed if the app terminates TLS itself (not behind a reverse proxy)
# FORCE_SSL=false

# Optional
# POOL_SIZE=10
# ECTO_IPV6=false

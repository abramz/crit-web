<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="liveview-transport"
      content={
        Application.get_env(:crit, CritWeb.Endpoint, [])
        |> Keyword.get(:liveview_transport, "websocket")
      }
    />
    <%= if sentry = Application.get_env(:crit, :sentry_frontend) do %>
      <meta name="sentry-dsn" content={sentry.dsn} />
      <meta name="sentry-environment" content={sentry.environment} />
      <meta :if={sentry[:release]} name="sentry-release" content={sentry.release} />
    <% end %>
    <meta
      name="description"
      content={
        assigns[:meta_description] ||
          "Your feedback loop with the agent. Review plans and code changes with inline comments, multi-round diffs, and structured output any AI coding agent can consume."
      }
    />
    <meta
      name="keywords"
      content="code review, AI plan review, inline comments, markdown review, AI coding agent, Claude Code, Cursor, feedback loop, agent review"
    />
    <%= if assigns[:noindex] || Application.get_env(:crit, :selfhosted) do %>
      <meta name="robots" content="noindex, nofollow" />
      <meta name="referrer" content="no-referrer" />
    <% end %>
    <link :if={assigns[:canonical_url]} rel="canonical" href={@canonical_url} />

    <meta property="og:type" content={assigns[:og_type] || "website"} />
    <meta property="og:site_name" content="Crit" />
    <meta
      property="og:title"
      content={assigns[:page_title] || "Crit — Your feedback loop with the agent"}
    />
    <meta
      property="og:description"
      content={
        assigns[:meta_description] ||
          "Your feedback loop with the agent. Review plans and code changes with inline comments, multi-round diffs, and structured output any AI coding agent can consume."
      }
    />
    <meta property="og:url" content={assigns[:canonical_url] || "https://crit.md"} />
    <meta property="og:image" content={assigns[:og_image] || "https://crit.md/images/og.png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={assigns[:page_title] || "Crit — Your feedback loop with the agent"}
    />
    <meta name="twitter:image" content={assigns[:og_image] || "https://crit.md/images/og.png"} />
    <meta
      name="twitter:description"
      content={
        assigns[:meta_description] ||
          "Your feedback loop with the agent. Review plans and code changes with inline comments, multi-round diffs, and structured output any AI coding agent can consume."
      }
    />

    <.live_title default="Crit — Your feedback loop with the agent">
      {assigns[:page_title]}
    </.live_title>
    {raw(
      if assigns[:json_ld],
        do: ~s(<script type="application/ld+json">#{JSON.encode!(assigns[:json_ld])}</script>),
        else: ""
    )}
    <link rel="icon" type="image/png" sizes="96x96" href={~p"/favicon-96x96.png"} />
    <link rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/site.webmanifest"} crossorigin="use-credentials" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script phx-track-static type="module" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const t = localStorage.getItem("phx:theme");
        if (t && t !== "system") {
          document.documentElement.setAttribute("data-theme", t);
        }
      })();
    </script>
  </head>
  <body class="bg-(--crit-bg-page) text-(--crit-fg-primary)">
    {@inner_content}
  </body>
</html>

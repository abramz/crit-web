<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-(--crit-bg-page) text-(--crit-fg-primary) font-sans flex flex-col">
  <Layouts.site_header current_scope={@current_scope} />

  <section class="max-w-7xl mx-auto pt-24 pb-16 px-10 w-full max-sm:px-4 max-sm:pt-14 max-sm:pb-10">
    <div class="max-w-4xl mb-14 max-sm:mb-10">
      <h1 class="text-7xl font-extrabold leading-none tracking-tight mb-7 max-lg:text-6xl max-sm:text-5xl">
        Point at the line. <br />
        <span class="whitespace-nowrap">
          Tell the agent<span class="text-(--crit-brand)">.</span>
          <span class="crit-blink-cursor">
            ▍
          </span>
        </span>
      </h1>
      <p class="text-xl max-sm:text-base leading-relaxed text-(--crit-fg-secondary) max-w-4xl mb-10 text-pretty">
        Your agent just touched 14 files. In the terminal you're scrolling through diffs hoping
        nothing broke. Crit opens those changes in a browser &mdash; click line 47, type
        "this drops the refresh token", and the agent fixes it. You see exactly what changed,
        round by round.
      </p>
      <div class="flex gap-6 items-start max-lg:flex-col max-lg:gap-4">
        <div class="max-w-md flex-1 min-w-0 max-lg:w-full">
          <CritWeb.PageHTML.install_widget id="hero-install" />
        </div>
        <div class="flex flex-col gap-3 shrink-0 pt-10 max-lg:pt-0 max-sm:w-full max-sm:items-center">
          <.github_star_link variant="hero" />
          <div class="flex items-center gap-3 max-sm:justify-center">
            <button
              type="button"
              data-video-open
              data-video-src="https://www.youtube.com/embed/LHwfdvePf5A?autoplay=1&rel=0"
              class="inline-flex items-center gap-2 text-sm font-semibold text-(--crit-fg-secondary) no-underline hover:text-(--crit-fg-primary) transition-colors cursor-pointer"
            >
              ▶ Watch 2-min video
            </button>
            <%= if @demo_token do %>
              <span class="text-(--crit-fg-muted)" aria-hidden="true">·</span>
              <a
                href={~p"/r/#{@demo_token}"}
                class="inline-flex items-center gap-2 text-sm font-semibold text-(--crit-fg-secondary) no-underline hover:text-(--crit-fg-primary) transition-colors"
              >
                See demo
              </a>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded-xl overflow-hidden shadow-lg">
      <video
        autoplay
        loop
        muted
        playsinline
        controls
        width="1920"
        height="1080"
        class="w-full h-auto"
        poster="https://assets.crit.md/crit-demo-poster.png"
        src="https://assets.crit.md/crit-demo.mp4"
      ></video>
    </div>

    <%!-- YouTube video modal --%>
    <div
      id="video-modal"
      hidden
      data-video-backdrop
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/80"
    >
      <div class="relative w-full max-w-[960px] mx-4" style="aspect-ratio: 16/9;">
        <iframe
          id="video-iframe"
          src=""
          title="Crit demo"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="absolute inset-0 w-full h-full rounded-xl"
          style="border: 0;"
        ></iframe>
        <button
          type="button"
          data-video-close
          class="absolute -top-10 right-0 text-white/70 hover:text-white text-2xl font-bold cursor-pointer"
          aria-label="Close video"
        >
          ✕
        </button>
      </div>
    </div>
  </section>

  <%!-- ===== Four Modes ===== --%>
  <section id="modes" class="py-16 max-sm:py-10">
    <div class="max-w-7xl mx-auto px-10 max-sm:px-4 w-full">
      <div class="max-w-2xl mb-16 max-sm:mb-10">
        <p class="font-mono text-xs tracking-widest uppercase text-(--crit-fg-muted) mb-4">
          Four review modes
        </p>
        <h2 class="text-4xl font-extrabold tracking-tight max-sm:text-3xl text-balance">
          Agents don't just write code<span class="text-(--crit-brand)">.</span>
        </h2>
        <p class="text-lg text-(--crit-fg-secondary) leading-relaxed mt-4">
          They write plans, generate HTML pages, modify running apps. Each output needs a different review surface &mdash; and terminal diffs work for none of them.
        </p>
      </div>

      <div class="flex flex-col gap-20">
        <div
          :for={{mode, idx} <- Enum.with_index(CritWeb.PageHTML.modes())}
          class="grid grid-cols-5 gap-12 items-center max-md:grid-cols-1"
        >
          <div class={[
            "col-span-2 max-md:col-span-1 max-md:order-none",
            rem(idx, 2) == 1 && "order-2"
          ]}>
            <p class="font-mono text-xs tracking-widest uppercase text-(--crit-fg-muted) mb-3">
              {String.upcase(mode.cmd)}
            </p>
            <h3 class="text-2xl font-bold tracking-tight mb-3">{mode.label}</h3>
            <p class="text-(--crit-fg-secondary) leading-relaxed mb-5">{mode.blurb}</p>
            <div class="flex flex-wrap gap-2 mb-5">
              <span
                :for={bullet <- mode.bullets}
                class="bg-(--crit-bg-elevated) border border-(--crit-border) rounded-full px-3 py-1 text-xs text-(--crit-fg-secondary)"
              >
                {bullet}
              </span>
            </div>
            <a
              href={"/modes/#{mode.slug}"}
              class="text-sm font-semibold text-(--crit-brand) no-underline hover:underline"
            >
              {mode.nav_label} &rarr;
            </a>
          </div>
          <div class={[
            "col-span-3 max-md:col-span-1 max-md:order-none",
            rem(idx, 2) == 1 && "order-1"
          ]}>
            <%= if mode[:video] do %>
              <div class="rounded-xl overflow-hidden shadow-lg">
                <video
                  autoplay
                  loop
                  muted
                  playsinline
                  controls
                  preload="none"
                  width="1920"
                  height="1080"
                  class="w-full h-auto"
                  poster={mode[:poster]}
                  data-lazy-src={mode.video}
                ></video>
              </div>
            <% else %>
              <CritWeb.PageHTML.browser_chrome url={"localhost:4923/#{mode.slug}"}>
                <%= if mode.screenshot do %>
                  <img
                    src={"/images/screenshots/#{mode.screenshot}-dark@1x.png"}
                    srcset={"/images/screenshots/#{mode.screenshot}-dark@1x.png 1x, /images/screenshots/#{mode.screenshot}-dark@2x.png 2x"}
                    alt={"Crit #{mode.label} mode"}
                    class="logo-dark w-full"
                    loading="lazy"
                    width="1200"
                    height="675"
                  />
                  <img
                    src={"/images/screenshots/#{mode.screenshot}-light@1x.png"}
                    srcset={"/images/screenshots/#{mode.screenshot}-light@1x.png 1x, /images/screenshots/#{mode.screenshot}-light@2x.png 2x"}
                    alt={"Crit #{mode.label} mode"}
                    class="logo-light w-full"
                    loading="lazy"
                    width="1200"
                    height="675"
                  />
                <% else %>
                  <CritWeb.PageHTML.browser_chrome_placeholder label={mode.label} />
                <% end %>
              </CritWeb.PageHTML.browser_chrome>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- ===== Integrations ===== --%>
  <section id="integrations" class="py-16 max-sm:py-10">
    <div class="max-w-7xl mx-auto px-10 max-sm:px-4 w-full">
      <div class="max-w-2xl mb-12 max-sm:mb-8">
        <h2 class="text-4xl font-extrabold tracking-tight mb-4 max-sm:text-3xl text-balance">
          Every agent reads files. That's the whole protocol<span class="text-(--crit-brand)">.</span>
        </h2>
        <p class="text-lg text-(--crit-fg-secondary) leading-relaxed">
          Crit writes a structured review file. Any agent that can read a file and run a command can use it &mdash; no API, no plugin framework, no vendor lock.
        </p>
      </div>

      <div class="grid grid-cols-[repeat(auto-fill,minmax(220px,1fr))] gap-3 mb-8">
        <a
          :for={
            id <-
              ~w(claude-code cursor github-copilot opencode codex gemini qwen hermes windsurf cline grok aider pi)
          }
          href={"/integrations/#{id}"}
          class="flex items-center gap-3 px-4 py-3 bg-(--crit-bg-card) border border-(--crit-border) rounded-lg no-underline hover:border-(--crit-fg-muted) hover:bg-(--crit-bg-elevated) transition-all group"
        >
          <img
            src={"/images/integrations/#{id}-dark.svg"}
            alt=""
            class="logo-dark size-7 object-contain shrink-0"
            loading="lazy"
          />
          <img
            src={"/images/integrations/#{id}-light.svg"}
            alt=""
            class="logo-light size-7 object-contain shrink-0"
            loading="lazy"
          />
          <span class="text-sm font-medium text-(--crit-fg-primary) flex-1">
            {id
            |> String.replace("-", " ")
            |> String.split()
            |> Enum.map(&String.capitalize/1)
            |> Enum.join(" ")}
          </span>
          <svg
            viewBox="0 0 20 20"
            fill="currentColor"
            class="size-4 text-(--crit-fg-muted) group-hover:text-(--crit-fg-secondary) transition-colors shrink-0"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M5 10a.75.75 0 01.75-.75h6.638L10.23 7.29a.75.75 0 111.04-1.08l3.5 3.25a.75.75 0 010 1.08l-3.5 3.25a.75.75 0 11-1.04-1.08l2.158-1.96H5.75A.75.75 0 015 10z"
              clip-rule="evenodd"
            />
          </svg>
        </a>
      </div>

      <div class="mt-10">
        <h3 class="text-lg font-bold tracking-tight mb-4">Connect your agent</h3>
        <CritWeb.PageHTML.agent_setup_widget />
      </div>
    </div>
  </section>

  <%!-- ===== Founder ===== --%>
  <section id="built-by" class="py-16 max-sm:py-10">
    <div class="max-w-3xl mx-auto px-10 max-sm:px-4 w-full">
      <h2 class="text-3xl font-extrabold tracking-tight mb-8 max-sm:text-2xl">
        I review <span class="text-(--crit-brand)">a lot</span>
        of agent output<span class="text-(--crit-brand)">.</span>
      </h2>
      <div class="flex gap-8 items-start max-sm:flex-col max-sm:gap-5">
        <img
          src="/images/founder/photo@1x.webp"
          srcset="/images/founder/photo@1x.webp 1x, /images/founder/photo@2x.webp 2x"
          alt="Tomasz's photo"
          class="size-32 shrink-0 rounded-full object-cover bg-(--crit-bg-card)"
          loading="lazy"
          width="128"
          height="128"
        />
        <div class="flex-1 min-w-0">
          <h3 class="text-base font-semibold tracking-tight mb-2">
            Hey, I'm <span class="text-(--crit-brand)">Tomasz</span>!
          </h3>
          <p class="leading-relaxed mb-3 text-(--crit-fg-secondary)">
            Staff engineer, 25 years of shipping code. When I started using AI agents full-time, the code generation was impressive &mdash; but I was spending more time re-reading terminal diffs than the agent spent writing the code. I kept missing things that a proper review surface would have caught in seconds.
          </p>
          <p class="leading-relaxed mb-3 text-(--crit-fg-secondary)">
            So I built <strong>Crit</strong>. I use it on every feature I ship. It gets a new release every week based on feedback from engineers who live in this same loop.
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-1 mt-4 text-xs text-(--crit-fg-muted)">
            <a
              href="https://github.com/tomasz-tomczyk"
              class="crit-link no-underline hover:underline"
            >
              GitHub
            </a>
            <a href="https://x.com/tomasztomczyk" class="crit-link no-underline hover:underline">
              Twitter
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- ===== Testimonials ===== --%>
  <section id="testimonials" class="py-16 max-sm:py-10">
    <div class="max-w-7xl mx-auto px-10 max-sm:px-4 w-full">
      <div class="max-w-2xl mb-12 max-sm:mb-8">
        <p class="font-mono text-xs tracking-widest uppercase text-(--crit-fg-muted) mb-4">
          What engineers say
        </p>
        <h2 class="text-4xl font-extrabold tracking-tight max-sm:text-3xl text-balance">
          The reviews from engineers who live in this loop<span class="text-(--crit-brand)">.</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 gap-8 max-sm:grid-cols-1 max-sm:gap-6">
        <div :for={testimonial <- @testimonials}>
          <p class="text-lg font-semibold leading-snug text-(--crit-fg-primary) mb-4">
            {testimonial.highlight}
          </p>
          <div class="space-y-2 mb-4">
            <p
              :for={paragraph <- testimonial.body}
              class="leading-relaxed text-(--crit-fg-secondary)"
            >
              {paragraph}
            </p>
          </div>
          <div class="flex items-center gap-3">
            <img
              src={testimonial.avatar}
              alt={testimonial.author}
              class="size-9 rounded-full bg-(--crit-bg-elevated) shrink-0"
              loading="lazy"
              width="36"
              height="36"
            />
            <p class="font-mono text-xs text-(--crit-fg-muted) leading-snug min-w-0">
              <a
                href={testimonial.link}
                class="text-(--crit-fg-secondary) hover:text-(--crit-brand) transition-colors no-underline"
                target="_blank"
                rel="noopener noreferrer"
              >
                {testimonial.author}
              </a>
              <br />{testimonial.role}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- ===== FAQ ===== --%>
  <section id="faq" class="py-16 max-sm:py-10">
    <div class="max-w-7xl mx-auto px-10 max-sm:px-4 w-full">
      <div class="max-w-2xl mb-12 max-sm:mb-8">
        <h2 class="text-4xl font-extrabold tracking-tight max-sm:text-3xl text-balance">
          Frequently asked questions
        </h2>
      </div>

      <div class="grid grid-cols-2 gap-8 max-md:grid-cols-1 max-md:gap-6">
        <div
          :for={item <- @faq}
          class="border border-(--crit-border) rounded-lg bg-(--crit-bg-card) p-6"
        >
          <h3 class="text-base font-bold tracking-tight mb-3 text-(--crit-fg-primary)">
            {item.q}
          </h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            {item.a}
          </p>
        </div>
      </div>
    </div>
  </section>

  <CritWeb.PageHTML.install_section id="bottom-install" />

  <Layouts.site_footer />
</div>
